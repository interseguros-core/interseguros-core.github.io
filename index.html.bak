        <a href="#registro-anulaciones"><span class="nav-icon">📋</span> Registro y Anulaciones</a>
        <a href="#whatsapp-hub"><span class="nav-icon">📱</span> WhatsApp IA Hub</a>
        <a href="#cotizadores"><span class="nav-icon">🧮</span> Cotizadores Param.</a>
        <a href="#firma-digital"><span class="nav-icon">🔒</span> Firma Digital</a>
