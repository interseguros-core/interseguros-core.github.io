        <div class="nav-group-label">Operaciones</div>
        <a href="#suscripcion"><span class="nav-icon">✍️</span> Suscripción y Emisión</a>
        <a href="#comisiones"><span class="nav-icon">💰</span> Comisiones Avanzadas</a>
        <a href="#conciliaciones"><span class="nav-icon">⚖️</span> Conciliaciones</a>
        <a href="#reporteria"><span class="nav-icon">📊</span> Reportería BI</a>
